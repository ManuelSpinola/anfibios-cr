#| label: ajuste-final
gam_model <- parsnip::gen_additive_mod(mode = "classification") |>
set_engine("mgcv",
family = binomial(link = "logit"),
method = "REML")
wf_especie            <- h3sdm_workflow_gam(gam_model, gam_rec_especie, formula_gam_final_especie)
presence_data_especie <- dat_especie_scaled |> filter(presence == 1)
mod_gam_especie       <- h3sdm_fit_model(wf_especie, scv_especie, presence_data_especie)
modelo_ajustado_especie <- workflows::extract_fit_engine(mod_gam_especie$final_model)
summary(modelo_ajustado_especie)
#| resumen-modelo
extraer_resumen_modelo <- function(modelo_ajustado, p_umbral = 0.05) {
s <- summary(modelo_ajustado)
tabla_smooth <- s$s.table |>
as.data.frame() |>
rownames_to_column("Término") |>
rename(
`GDL efectivos` = edf,
`GDL ref.`      = Ref.df,
`Chi²`          = Chi.sq,
`p-valor`       = `p-value`
) |>
mutate(across(where(is.numeric), \(x) round(x, 4)),
significativo = `p-valor` < p_umbral)
metricas <- tibble(
`R² ajustado`           = round(s$r.sq, 3),
`Devianza explicada (%)` = round(s$dev.expl * 100, 1),
`n`                      = s$n,
`REML`                   = round(s$sp.criterion, 3)
)
list(smooth = tabla_smooth, metricas = metricas)
}
resumen   <- extraer_resumen_modelo(modelo_ajustado_especie)
filas_sig <- which(resumen$smooth$significativo)
resumen$smooth |>
select(-significativo) |>
tt(caption = "Términos suavizados del modelo GAM") |>
style_tt(i = filas_sig, background = "#e8f4e8", bold = TRUE)
#| label: metricas-gam
tt(resumen$metricas, caption = "Métricas generales del modelo")
#| label: eval-metrics
evaluation_metrics_especie <- h3sdm_eval_metrics(
fitted_model  = mod_gam_especie$cv_model,
presence_data = presence_data_especie
)
evaluation_metrics_especie |>
rename(
`Métrica`     = .metric,
`Estimador`   = .estimator,
`Media`       = mean,
`Error std`   = std_err,
`IC inferior` = conf_low,
`IC superior` = conf_high
) |>
tt(digits = 2, caption = "Métricas de evaluación — CV espacial")
#| label: prediccion-presente
pred_presente_especie <- h3sdm_predict(mod_gam_especie, predictors)
#| label: mapa-presente
#| fig.cap: "Distribución potencial presente"
ggplot() +
theme_minimal() +
geom_sf(data = pred_presente_especie, aes(fill = prediction), color = "transparent") +
geom_sf(data = cr, fill = "transparent", color = "grey30", linewidth = 0.3) +
scale_fill_viridis_c(name = "Idoneidad\nde hábitat", option = "B", direction = -1) +
labs(title = params$species, subtitle = "Escenario presente")
#| label: prediccion-futuro
pred_futuro_especie <- h3sdm_predict(mod_gam_especie, predictors_futuro)
#| label: mapa-futuro
#| fig-cap: "Distribución potencial futura"
ggplot() +
theme_minimal() +
geom_sf(data = pred_futuro_especie, aes(fill = prediction), color = "transparent") +
geom_sf(data = cr, fill = "transparent", color = "grey30", linewidth = 0.3) +
scale_fill_viridis_c(name = "Idoneidad\nde hábitat", option = "B", direction = -1) +
labs(title = params$species, subtitle = "Escenario futuro")
#| label: comparacion
comparacion <- pred_presente_especie |>
st_drop_geometry() |>
rename(presente = prediction) |>
left_join(
pred_futuro_especie |> st_drop_geometry() |> rename(futuro = prediction),
by = "h3_address"
) |>
mutate(cambio = futuro - presente)
comparacion_sf <- pred_presente_especie |>
select(h3_address, geometry) |>
left_join(comparacion, by = "h3_address")
#| label: mapa-cambio
#| fig-cap: "Cambio en idoneidad (futuro − presente)"
lim <- max(abs(comparacion$cambio), na.rm = TRUE)
ggplot() +
theme_minimal() +
geom_sf(data = comparacion_sf, aes(fill = cambio), color = "transparent") +
geom_sf(data = cr, fill = "transparent", color = "grey30", linewidth = 0.3) +
scale_fill_distiller(
name    = "Cambio\nen idoneidad",
palette = "RdBu",
direction = 1,
limits  = c(-lim, lim)
) +
labs(title = params$species, subtitle = "Diferencia futuro − presente")
summary(comparacion$cambio)
#| label: stats-cambio
comparacion |>
summarise(
`Ganancia (n hex)`  = sum(cambio >  0.1, na.rm = TRUE),
`Pérdida (n hex)`   = sum(cambio < -0.1, na.rm = TRUE),
`Sin cambio (n hex)` = sum(abs(cambio) <= 0.1, na.rm = TRUE),
`Cambio medio`       = round(mean(cambio, na.rm = TRUE), 3)
) |>
tt(caption = "Resumen de cambio presente → futuro")
clasificar_habitat <- function(x) {
cut(x,
breaks = c(0, 0.2, 0.4, 0.6, 0.8, 1),
labels = c("Muy bajo", "Bajo", "Medio", "Alto", "Muy alto"),
include.lowest = TRUE)
}
#| include: true
# Clasificar ambos escenarios
# Clasificar ambos escenarios
presente_cat <- pred_presente_especie |>
mutate(
categoria = clasificar_habitat(prediction),
area_km2  = as.numeric(st_area(geometry)) / 1e6
)
futuro_cat <- pred_futuro_especie |>
mutate(
categoria = clasificar_habitat(prediction),
area_km2  = as.numeric(st_area(geometry)) / 1e6
)
# Sumar área por categoría
area_presente <- presente_cat |>
st_drop_geometry() |>
group_by(categoria) |>
summarise(area_km2 = sum(area_km2)) |>
mutate(escenario = "Presente")
area_futuro <- futuro_cat |>
st_drop_geometry() |>
group_by(categoria) |>
summarise(area_km2 = sum(area_km2)) |>
mutate(escenario = "Futuro")
comparacion_area <- bind_rows(area_presente, area_futuro) |>
mutate(escenario = factor(escenario, levels = c("Presente", "Futuro")))
#| include: TRUE
#| echo: TRUE
# Visualizar
ggplot(comparacion_area, aes(x = categoria, y = area_km2, fill = escenario)) +
geom_col(position = "dodge") +
theme_minimal() +
labs(x = "Categoría de hábitat",
y = "Área (km²)",
fill = "Escenario") +
scale_fill_tableau()
#| label: comparacion-categorias
comparacion_categorias <- presente_cat |>
st_drop_geometry() |>
select(h3_address, cat_presente = categoria) |>
left_join(
futuro_cat |>
st_drop_geometry() |>
select(h3_address, cat_futuro = categoria),
by = "h3_address"
) |>
filter(!is.na(cat_presente), !is.na(cat_futuro))
library(plotly)
flujos_plot <- comparacion_categorias |>
count(cat_presente, cat_futuro, name = "value")
niveles <- c("Muy alto", "Alto", "Medio", "Bajo", "Muy bajo")
colores_nodos <- c("#1a9641", "#a6d96a", "#ffffbf", "#fdae61", "#d7191c")
# Nodos: presente + futuro
nodos_labels <- c(
paste0("Presente: ", niveles),
paste0("Futuro: ",   niveles)
)
nodos_colores <- rep(colores_nodos, 2)
# Índices
source_idx <- match(paste0("Presente: ", flujos_plot$cat_presente), nodos_labels) - 1
target_idx <- match(paste0("Futuro: ",   flujos_plot$cat_futuro),   nodos_labels) - 1
sankey_plotly <- plot_ly(
type = "sankey",
orientation = "h",
node = list(
label = nodos_labels,
color = nodos_colores,
pad   = 15,
thickness = 20
),
link = list(
source = source_idx,
target = target_idx,
value  = flujos_plot$value
)
) |>
layout(
title = list(text = paste0(params$species,
"<br><sup>Cambio en categorías de idoneidad de hábitat</sup>")),
font  = list(size = 12)
)
sankey_plotly
#| label: cargar-sinac
h3_sinac       <- readRDS(here("vectores_para_modelos/h8_sinac.rds"))
asp_terrestres <- readRDS(here("vectores_para_modelos/asp_terrestres_cr.rds"))
# Umbral que maximiza TSS (índice J de Youden = sensibilidad + especificidad - 1)
umbral_tss <- pred_presente_especie |>
st_drop_geometry() |>
left_join(
especie_balanced_data |>
st_drop_geometry() |>
select(h3_address, presence),
by = "h3_address"
) |>
drop_na(presence, prediction) |>
mutate(presence = as.integer(as.character(presence))) |>
reframe(
threshold = seq(0.01, 0.99, 0.01),
sens = map_dbl(threshold, ~ mean(prediction[presence == 1] >= .x)),
spec = map_dbl(threshold, ~ mean(prediction[presence == 0] <  .x)),
tss  = sens + spec - 1
) |>
slice_max(tss, n = 1) |>
pull(threshold)
cat("Umbral TSS:", umbral_tss, "\n")
umbral <- umbral_tss
#| label: mapa-asp-presente
#| fig-cap: "Distribución potencial presente y áreas protegidas"
ggplot() +
theme_minimal() +
geom_sf(data = pred_presente_especie, aes(fill = prediction),
color = "transparent") +
geom_sf(data = asp_terrestres, fill = "transparent",
color = "#00c853", linewidth = 0.3) +
geom_sf(data = cr, fill = "transparent",
color = "grey30", linewidth = 0.3) +
scale_fill_viridis_c(name = "Idoneidad\nde hábitat",
option = "B", direction = -1) +
labs(title = params$species, subtitle = "Escenario presente")
#| label: mapa-asp-futuro
#| fig-cap: "Distribución potencial futura y áreas protegidas"
ggplot() +
theme_minimal() +
geom_sf(data = pred_futuro_especie, aes(fill = prediction),
color = "transparent") +
geom_sf(data = asp_terrestres, fill = "transparent",
color = "#00c853", linewidth = 0.3) +
geom_sf(data = cr, fill = "transparent",
color = "grey30", linewidth = 0.3) +
scale_fill_viridis_c(name = "Idoneidad\nde hábitat",
option = "B", direction = -1) +
labs(title = params$species, subtitle = "Escenario futuro")
#| label: cobertura-asp-presente
area_por_hex_p <- pred_presente_especie |>
mutate(area_km2 = as.numeric(st_area(geometry)) / 1e6)
cobertura_presente <- area_por_hex_p |>
st_drop_geometry() |>
mutate(presente = prediction >= umbral) |>
left_join(h3_sinac, by = "h3_address") |>
summarise(
area_distribucion_km2 = round(sum(area_km2[presente]), 1),
area_protegida_km2    = round(sum(area_km2[presente & protegido], na.rm = TRUE), 1),
pct_protegido         = round(area_protegida_km2 / area_distribucion_km2 * 100, 1)
) |>
mutate(escenario = "Presente")
#| label: cobertura-asp-futuro
area_por_hex_f <- pred_futuro_especie |>
mutate(area_km2 = as.numeric(st_area(geometry)) / 1e6)
cobertura_futuro <- area_por_hex_f |>
st_drop_geometry() |>
mutate(presente = prediction >= umbral) |>
left_join(h3_sinac, by = "h3_address") |>
summarise(
area_distribucion_km2 = round(sum(area_km2[presente]), 1),
area_protegida_km2    = round(sum(area_km2[presente & protegido], na.rm = TRUE), 1),
pct_protegido         = round(area_protegida_km2 / area_distribucion_km2 * 100, 1)
) |>
mutate(escenario = "Futuro")
#| label: tabla-cobertura-asp
bind_rows(cobertura_presente, cobertura_futuro) |>
select(escenario, everything()) |>
rename(
`Escenario`               = escenario,
`Área distribución (km²)` = area_distribucion_km2,
`Área protegida (km²)`    = area_protegida_km2,
`% protegido`             = pct_protegido
) |>
tt(caption = "Cobertura de la distribución en áreas protegidas")
#| label: asp-por-categoria
asp_presente_cat <- area_por_hex_p |>
st_drop_geometry() |>
mutate(presente = prediction >= umbral) |>
filter(presente) |>
left_join(h3_sinac, by = "h3_address") |>
filter(protegido) |>
group_by(cat_manejo, siglas_cat) |>
summarise(presente = round(sum(area_km2), 1), .groups = "drop")
asp_futuro_cat <- area_por_hex_f |>
st_drop_geometry() |>
mutate(presente = prediction >= umbral) |>
filter(presente) |>
left_join(h3_sinac, by = "h3_address") |>
filter(protegido) |>
group_by(cat_manejo, siglas_cat) |>
summarise(futuro = round(sum(area_km2), 1), .groups = "drop")
tabla_asp_cat <- full_join(asp_presente_cat, asp_futuro_cat,
by = c("cat_manejo", "siglas_cat")) |>
mutate(
presente   = replace_na(presente, 0),
futuro     = replace_na(futuro, 0),
diferencia = round(futuro - presente, 1)
) |>
arrange(desc(presente)) |>
rename(
`Categoría`        = cat_manejo,
`Siglas`           = siglas_cat,
`Presente (km²)`   = presente,
`Futuro (km²)`     = futuro,
`Diferencia (km²)` = diferencia
)
filas_ganancia <- which(tabla_asp_cat$`Diferencia (km²)` > 0)
filas_perdida  <- which(tabla_asp_cat$`Diferencia (km²)` < 0)
tabla_asp_cat |>
tt(caption = "Cobertura por categoría de manejo — presente y futuro (km²)") |>
style_tt(i = filas_ganancia, j = 5, color = "darkgreen", bold = TRUE) |>
style_tt(i = filas_perdida,  j = 5, color = "red",       bold = TRUE)
#| label: outputs
# Guardar outputs
ruta <- here("modelos", tax_especie$order, tax_especie$family,
gsub(" ", "_", params$species))
dir.create(ruta, recursive = TRUE, showWarnings = FALSE)
saveRDS(presencias_centroides,      file.path(ruta, "presencias.rds"))
saveRDS(mod_gam_especie,            file.path(ruta, "model.rds"))
saveRDS(pred_presente_especie,      file.path(ruta, "pred_presente.rds"))
saveRDS(pred_futuro_especie,        file.path(ruta, "pred_futuro.rds"))
saveRDS(evaluation_metrics_especie, file.path(ruta, "metrics.rds"))
saveRDS(comparacion_sf,             file.path(ruta, "comparacion_sf.rds"))
saveRDS(comparacion_area,           file.path(ruta, "comparacion_area.rds"))
saveRDS(sankey_plotly,              file.path(ruta, "sankey.rds"))
saveRDS(umbral_tss,                 file.path(ruta, "umbral_tss.rds"))
saveRDS(cobertura_presente,         file.path(ruta, "cobertura_asp_presente.rds"))
saveRDS(cobertura_futuro,           file.path(ruta, "cobertura_asp_futuro.rds"))
beep()
library(tidyverse)
library(easystats)
library(here)
library(sf)
library(terra)
library(tidymodels)
library(tidysdm)
library(h3sdm)
library(tinytable)
library(mgcv)
library(MuMIn)
library(networkD3)
library(htmlwidgets)
library(ggthemes)
library(probably)
library(beepr)
all |>
filter(order == "Anura") |>
distinct(family) |>
arrange(family)
all |>
filter(family == "Craugastoridae") |>
count(species) |>
arrange(n)
#| label: cargar-datos
cr                <- readRDS(here("vectores_para_modelos/cr.rds"))
taxonomia         <- readRDS(here("datos/taxonomia.rds"))
predictors        <- readRDS(here("vectores_para_modelos/predictores_presente_finales_h8_sf.rds"))
predictors_futuro <- readRDS(here("vectores_para_modelos/predictores_futuro_finales_h8_sf.rds"))
#| label: taxonomia
tax_especie <- taxonomia |> filter(species == params$species)
#| label: registros-especie
especie <- h3sdm_pa(
species           = params$species,
aoi_sf            = cr_outline_c,
res               = 8,
n_pseudoabs       = 0,
providers         = c("gbif", "inat"),
remove_duplicates = TRUE
) |>
st_transform(5367)
sum(especie$presence == 1)
#| label: verificar-n
n_celdas <- especie |>
filter(presence == 1) |>
summarise(n = n_distinct(h3_address)) |>
pull(n)
cat("Celdas H3 ocupadas:", n_celdas, "\n")
if (n_celdas < 30) {
msg <- glue::glue(
"ESPECIE DESCARTADA: solo {n_celdas} celdas H3 ocupadas (mínimo: 30)."
)
if (isTRUE(getOption("knitr.in.progress"))) {
knitr::knit_exit(paste0("### Especie descartada\n\n", msg))
} else {
stop(msg)
}
}
#| label: setup
#| include: false
library(tidyverse)
library(sf)
library(here)
library(quarto)
#| label: seleccion
orden_actual   <- "Anura"
familia_actual <- "Craugastoridae"
#| label: especies
taxonomia <- readRDS(here("datos/taxonomia.rds"))
especies <- taxonomia |>
filter(order == orden_actual, family == familia_actual) |>
pull(species)
especies
#| label: verificar
archivos_necesarios <- c("model.rds", "pred_presente.rds", "pred_futuro.rds",
"metrics.rds", "presencias.rds",
"comparacion_sf.rds", "comparacion_area.rds",
"sankey.rds")
verificacion <- map_dfr(especies, function(sp) {
ruta <- here("modelos", orden_actual, familia_actual, gsub(" ", "_", sp))
tibble(
especie   = sp,
completo  = all(file.exists(file.path(ruta, archivos_necesarios))),
faltantes = paste(
archivos_necesarios[!file.exists(file.path(ruta, archivos_necesarios))],
collapse = ", "
)
)
})
verificacion
#| label: renderizar
especies_completas <- verificacion |>
filter(completo == TRUE) |>
pull(especie)
message("Especies a renderizar: ", length(especies_completas), " de ", length(especies))
ruta_template <- here("scripts", "reporte_template_claude.qmd")
walk(especies_completas, function(sp) {
tax       <- taxonomia |> filter(species == sp)
subtitulo <- paste(tax$order, "›", tax$family)
message("⏳ Renderizando: ", sp)
quarto_render(
input          = ruta_template,
output_file    = paste0(gsub(" ", "_", sp), ".html"),
execute_params = list(
species  = sp,
subtitle = subtitulo
)
)
nombre_html <- paste0(gsub(" ", "_", sp), ".html")
file.rename(
from = here("scripts", nombre_html),
to   = here("reportes", nombre_html)
)
message("✓ Listo: ", sp)
})
#| label: setup
#| include: false
library(tidyverse)
library(sf)
library(here)
library(quarto)
#| label: seleccion
orden_actual   <- "Anura"
familia_actual <- "Craugastoridae"
#| label: especies
taxonomia <- readRDS(here("datos/taxonomia.rds"))
especies <- taxonomia |>
filter(order == orden_actual, family == familia_actual) |>
pull(species)
especies
#| label: verificar
archivos_necesarios <- c("model.rds", "pred_presente.rds", "pred_futuro.rds",
"metrics.rds", "presencias.rds",
"comparacion_sf.rds", "comparacion_area.rds",
"sankey.rds")
verificacion <- map_dfr(especies, function(sp) {
ruta <- here("modelos", orden_actual, familia_actual, gsub(" ", "_", sp))
tibble(
especie   = sp,
completo  = all(file.exists(file.path(ruta, archivos_necesarios))),
faltantes = paste(
archivos_necesarios[!file.exists(file.path(ruta, archivos_necesarios))],
collapse = ", "
)
)
})
verificacion
#| label: renderizar
especies_completas <- verificacion |>
filter(completo == TRUE) |>
pull(especie)
message("Especies a renderizar: ", length(especies_completas), " de ", length(especies))
ruta_template <- here("scripts", "reporte_template_claude.qmd")
walk(especies_completas, function(sp) {
tax       <- taxonomia |> filter(species == sp)
subtitulo <- paste(tax$order, "›", tax$family)
message("⏳ Renderizando: ", sp)
quarto_render(
input          = ruta_template,
output_file    = paste0(gsub(" ", "_", sp), ".html"),
execute_params = list(
species  = sp,
subtitle = subtitulo
)
)
nombre_html <- paste0(gsub(" ", "_", sp), ".html")
file.rename(
from = here("scripts", nombre_html),
to   = here("reportes", nombre_html)
)
message("✓ Listo: ", sp)
})
